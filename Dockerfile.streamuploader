# syntax=docker/dockerfile:1

FROM golang:1.26-bookworm AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=1 go build -o /out/streamuploader ./cmd/streamuploader

FROM gcr.io/distroless/base-debian12
COPY --from=build /out/streamuploader /streamuploader
USER nonroot:nonroot
EXPOSE 8080
ENTRYPOINT ["/streamuploader"]
